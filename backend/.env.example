PORT=8787
ALLOWED_ORIGIN=*
LINK_TTL_MINUTES=1440

# mock | handy | plexo
PAYMENT_MODE=mock

# Needed only when PAYMENT_MODE=handy
HANDY_CREATE_URL=
HANDY_TOKEN=

# Needed only when PAYMENT_MODE=plexo
PLEXO_GATEWAY_URL=https://testing.plexo.com.uy:4043/SecurePaymentGateway.svc
PLEXO_CLIENT_NAME=
PLEXO_CERT_PASSWORD=
PLEXO_CERT_FINGERPRINT=
PLEXO_PFX_PATH=
PLEXO_PFX_BASE64=
PLEXO_REDIRECT_URL=https://rominagrasso.github.io/SacramentoShop/Home/index.html
PLEXO_COMMERCE_ID=

# Optional: datos de ejemplo tipo manual ExpressCheckout (ClientInformation)
# PLEXO_CHECKOUT_EMAIL=
# PLEXO_CHECKOUT_NAME=Sacramento Guest
# PLEXO_CHECKOUT_DOC=12345678
# PLEXO_LIMIT_ISSUERS=4,11,15

# Set to 1 on Render temporarily to log Plexo Auth response shape (no secrets).
# PAYMENT_DEBUG_LOG=1
